{
  "expo": {
    "name": "VitaSang",
    "slug": "VitaSang",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Capture d’écran du 2026-01-31 23-07-03.png",
    "scheme": [
      "vitasang"
    ],
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hidari-dev.VitaSang"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.hidari_dev.VitaSang",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCNJgLLOSVvUK0D2vEFQMigNHC2YTElIhY"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/Capture d’écran du 2026-01-31 23-07-03.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Capture d’écran du 2026-01-31 23-07-03.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-localization",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
