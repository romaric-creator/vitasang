# Gemini CLI Configuration

# Cache settings
CACHE_TTL=86400       # 24 hours

# Agent timeout
AGENT_TIMEOUT=300     # 5 minutes

# Verbose output
VERBOSE=false

# Auto-fix mode
AUTO_FIX=false

# Git settings
GIT_VERIFY=true       # Verify commits before push
GIT_SIGN=false        # Sign commits (if configured)

# Deployment
DEPLOY_VERIFY=true    # Ask confirmation for prod
DEPLOY_BACKUP=true    # Create backup before deploy

# Monitoring
ENABLE_STATS=true     # Track usage statistics
NOTIFY_ON_ERROR=true  # Notify when agent fails
