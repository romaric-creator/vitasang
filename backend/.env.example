# ============================================
# VITASANG BACKEND - VARIABLES D'ENVIRONNEMENT
# ============================================
# INSTRUCTIONS:
# 1. Copier ce fichier: cp .env.example .env
# 2. Remplir toutes les valeurs avec ***
# 3. JAMAIS committer le .env dans Git
# 4. Sur Render: Ajouter via Dashboard > Settings > Environment

# ============================================
# DATABASE (MySQL/MariaDB/Planetscale)
# ============================================
# Pour Render + Planetscale gratuit:
# https://planetscale.com -> Create Database
DB_HOST=your-db-host.psdb.cloud
DB_USER=database_username
DB_PASSWORD=your_secure_password_here
DB_NAME=vitasang_prod
DB_PORT=3306
DB_DIALECT=mysql
DB_LOGGING=false

# ============================================
# REDIS (Cache & Queue - OPTIONNEL)
# ============================================
# Gratuit: https://upstash.com (sans carte bancaire)
# Format: redis://default:PASSWORD@HOST:PORT
REDIS_URL=redis://default:your_token@your-host.upstash.io:30000

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=production
PORT=8000
LOG_LEVEL=info

# ============================================
# JWT (Authentification)
# ============================================
# Générer: openssl rand -hex 32
# Minimum 32 caractères
JWT_SECRET=your_super_long_secure_jwt_secret_minimum_32_chars_change_this
JWT_EXPIRE=24h

# ============================================
# EXPO NOTIFICATIONS
# ============================================
# Token Expo: https://expo.dev -> Settings > Access Tokens
EXPO_ACCESS_TOKEN=your_expo_access_token_here

# ============================================
# CLOUDINARY (Image Upload - OPTIONNEL)
# ============================================
# Gratuit: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=vitasang

# ============================================
# CORS CONFIGURATION
# ============================================
# URLs séparées par des virgules
CORS_ORIGIN=https://vitasang.onrender.com,https://vitasang.vercel.app,https://app.vitasang.com,http://localhost:3000,http://localhost:8081

# ============================================
# FILE UPLOAD
# ============================================
MAX_FILE_SIZE=50mb
UPLOAD_DIR=./uploads

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=15000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# ERROR MONITORING (OPTIONNEL)
# ============================================
# Sentry: https://sentry.io -> Create Project
SENTRY_DSN=https://your-sentry@sentry.io/project-id
