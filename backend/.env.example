# ============================================
# VITASANG BACKEND - VARIABLES D'ENVIRONNEMENT
# ============================================

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=vitasang
DB_PORT=3306
DB_LOGGING=false

# Redis Configuration (Nécessaire en Production pour Limiter/BullMQ)
REDIS_URL=redis://default:motdepasse...upstash.io:30000

# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_change_this_in_production_12345
JWT_EXPIRE=24h

# Expo Push Notifications
EXPO_ACCESS_TOKEN=your_expo_access_token_here

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:8081,http://10.139.176.208:8081

# File Upload Configuration
MAX_FILE_SIZE=50mb
UPLOAD_DIR=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=15000
RATE_LIMIT_MAX_REQUESTS=100
