{
	"info": {
		"_postman_id": "a8a0b5a3-6b3c-4e3e-8f8f-3f3e3e3e3e3e",
		"name": "VitaSang API - Test Flow",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"description": "Un flux de test pour enregistrer un utilisateur, se connecter, et créer une alerte."
	},
	"item": [
		{
			"name": "Étape 1: Enregistrer un nouvel utilisateur",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 201 || pm.response.code === 200) {",
							"    const requestBody = JSON.parse(pm.request.body.raw);",
							"    pm.collectionVariables.set(\"newUserPhone\", requestBody.telephone);",
							"    console.log('Téléphone sauvegardé :', requestBody.telephone);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"role\": \"donneur\",\n    \"nom\": \"Test\",\n    \"prenom\": \"Donneur\",\n    \"mot_de_passe\": \"password123\",\n    \"telephone\": \"+237690000003\",\n    \"groupe_sanguin\": \"A+\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/users/register",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"users",
						"register"
					]
				}
			},
			"response": []
		},
		{
			"name": "Étape 2: Se connecter",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 200) {",
							"    const jsonData = pm.response.json();",
							"    const token = jsonData.token || jsonData.accessToken;",
							"    pm.collectionVariables.set(\"authToken\", token);",
							"    console.log('Jeton d’authentification sauvegardé.');",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"telephone\": \"{{newUserPhone}}\",\n    \"mot_de_passe\": \"password123\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/users/login",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"users",
						"login"
					]
				}
			},
			"response": []
		},
		{
			"name": "Étape 3: Lancer une alerte (A+)",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{authToken}}",
							"type": "string"
						}
					]
				},
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"latitude\": 4.0839862,\n    \"longitude\": 9.7809086,\n    \"groupe_sanguin\": \"A+\",\n    \"radius\": 10,\n    \"urgence\": \"URGENT\",\n    \"quantite_requise\": 2,\n    \"lieu\": \"Hôpital de district de Bonassama, Douala\",\n    \"description\": \"Besoin urgent suite à un accident.\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/alerts/search",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"alerts",
						"search"
					]
				}
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000/api",
			"type": "string"
		},
		{
			"key": "newUserPhone",
			"value": "",
			"type": "string"
		},
		{
			"key": "authToken",
			"value": "",
			"type": "string"
		}
	]
}