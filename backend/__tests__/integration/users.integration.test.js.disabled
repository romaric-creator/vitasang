const request = require('supertest');
const app = require('../../index');
const db = require('../../models');
const jwt = require('jsonwebtoken');

describe('User Endpoints Integration Tests', () => {
  let authToken;
  let testUserId;

  beforeAll(async () => {
    // Sync database for tests
    await db.sequelize.sync({ force: false });
  });

  afterAll(async () => {
    await db.sequelize.close();
  });

  describe('POST /api/auth/register', () => {
    it('should successfully register a new user', async () => {
      const response = await request(app)
        .post('/api/auth/register')
        .send({
          nom: 'Test',
          prenom: 'User',
          telephone: '+212612345678',
          mot_de_passe: 'TestPassword123',
          groupe_sanguin: 'O+',
          ville: 'Casablanca',
          date_naissance: '1990-01-15'
        });

      expect(response.status).toBe(201);
      expect(response.body.message).toBeDefined();
      expect(response.body.token).toBeDefined();
      authToken = response.body.token;
    });

    it('should reject registration with invalid email/phone format', async () => {
      const response = await request(app)
        .post('/api/auth/register')
        .send({
          nom: 'Test',
          prenom: 'User',
          telephone: 'invalid-phone',
          mot_de_passe: 'TestPassword123',
          groupe_sanguin: 'O+',
          ville: 'Casablanca'
        });

      expect(response.status).toBe(400);
      expect(response.body.error).toBeDefined();
    });

    it('should reject registration with weak password', async () => {
      const response = await request(app)
        .post('/api/auth/register')
        .send({
          nom: 'Test',
          prenom: 'User',
          telephone: '+212612345678',
          mot_de_passe: '123',
          groupe_sanguin: 'O+',
          ville: 'Casablanca'
        });

      expect(response.status).toBe(400);
      expect(response.body.error).toBeDefined();
    });

    it('should reject registration with invalid blood type', async () => {
      const response = await request(app)
        .post('/api/auth/register')
        .send({
          nom: 'Test',
          prenom: 'User',
          telephone: '+212612345678',
          mot_de_passe: 'TestPassword123',
          groupe_sanguin: 'INVALID',
          ville: 'Casablanca'
        });

      expect(response.status).toBe(400);
      expect(response.body.error).toBeDefined();
    });

    it('should reject registration with missing required fields', async () => {
      const response = await request(app)
        .post('/api/auth/register')
        .send({
          nom: 'Test'
        });

      expect(response.status).toBe(400);
      expect(response.body.error).toBeDefined();
    });
  });

  describe('POST /api/auth/login', () => {
    beforeEach(async () => {
      // Create a test user first
      await request(app)
        .post('/api/auth/register')
        .send({
          nom: 'Login',
          prenom: 'Test',
          telephone: '+212698765432',
          mot_de_passe: 'LoginTest123',
          groupe_sanguin: 'AB+',
          ville: 'Marrakech'
        });
    });

    it('should successfully login with valid credentials', async () => {
      const response = await request(app)
        .post('/api/auth/login')
        .send({
          telephone: '+212698765432',
          mot_de_passe: 'LoginTest123'
        });

      expect(response.status).toBe(200);
      expect(response.body.token).toBeDefined();
      expect(response.body.user).toBeDefined();
      authToken = response.body.token;
    });

    it('should reject login with invalid phone', async () => {
      const response = await request(app)
        .post('/api/auth/login')
        .send({
          telephone: 'invalid-phone',
          mot_de_passe: 'LoginTest123'
        });

      expect(response.status).toBe(400);
    });

    it('should reject login with incorrect password', async () => {
      const response = await request(app)
        .post('/api/auth/login')
        .send({
          telephone: '+212698765432',
          mot_de_passe: 'WrongPassword'
        });

      expect(response.status).toBe(401);
    });

    it('should reject login with non-existent user', async () => {
      const response = await request(app)
        .post('/api/auth/login')
        .send({
          telephone: '+212699999999',
          mot_de_passe: 'AnyPassword'
        });

      expect(response.status).toBe(401);
    });
  });

  describe('POST /api/users/search-donors', () => {
    it('should search for donors with valid parameters', async () => {
      const response = await request(app)
        .post('/api/users/search-donors')
        .send({
          coordinates: {
            lat: 33.5731,
            lng: -7.5898
          },
          radius: 5,
          groupe_sanguin: 'O+'
        });

      expect(response.status).toBe(200);
      expect(response.body.donors).toBeDefined();
      expect(Array.isArray(response.body.donors)).toBe(true);
    });

    it('should reject search with invalid coordinates', async () => {
      const response = await request(app)
        .post('/api/users/search-donors')
        .send({
          coordinates: {
            lat: 'invalid',
            lng: -7.5898
          },
          radius: 5
        });

      expect(response.status).toBe(400);
    });

    it('should reject search with invalid radius', async () => {
      const response = await request(app)
        .post('/api/users/search-donors')
        .send({
          coordinates: {
            lat: 33.5731,
            lng: -7.5898
          },
          radius: -5
        });

      expect(response.status).toBe(400);
    });
  });

  describe('POST /api/users/update-location', () => {
    it('should update user location with valid token', async () => {
      // First login to get token
      const loginResponse = await request(app)
        .post('/api/auth/login')
        .send({
          telephone: '+212698765432',
          mot_de_passe: 'LoginTest123'
        });

      const token = loginResponse.body.token;

      const response = await request(app)
        .post('/api/users/update-location')
        .set('Authorization', `Bearer ${token}`)
        .send({
          latitude: 33.5731,
          longitude: -7.5898
        });

      expect(response.status).toBe(200);
    });

    it('should reject location update without token', async () => {
      const response = await request(app)
        .post('/api/users/update-location')
        .send({
          latitude: 33.5731,
          longitude: -7.5898
        });

      expect(response.status).toBe(403);
    });

    it('should reject location update with invalid coordinates', async () => {
      const loginResponse = await request(app)
        .post('/api/auth/login')
        .send({
          telephone: '+212698765432',
          mot_de_passe: 'LoginTest123'
        });

      const token = loginResponse.body.token;

      const response = await request(app)
        .post('/api/users/update-location')
        .set('Authorization', `Bearer ${token}`)
        .send({
          latitude: 'invalid',
          longitude: -7.5898
        });

      expect(response.status).toBe(400);
    });
  });

  describe('POST /api/users/push-token', () => {
    it('should register push token with valid data', async () => {
      const loginResponse = await request(app)
        .post('/api/auth/login')
        .send({
          telephone: '+212698765432',
          mot_de_passe: 'LoginTest123'
        });

      const token = loginResponse.body.token;

      const response = await request(app)
        .post('/api/users/push-token')
        .set('Authorization', `Bearer ${token}`)
        .send({
          token: 'ExponentPushToken[' + 'a'.repeat(64) + ']'
        });

      expect(response.status).toBe(200);
    });

    it('should reject invalid push token format', async () => {
      const loginResponse = await request(app)
        .post('/api/auth/login')
        .send({
          telephone: '+212698765432',
          mot_de_passe: 'LoginTest123'
        });

      const token = loginResponse.body.token;

      const response = await request(app)
        .post('/api/users/push-token')
        .set('Authorization', `Bearer ${token}`)
        .send({
          token: 'invalid-token'
        });

      expect(response.status).toBe(400);
    });
  });
});
